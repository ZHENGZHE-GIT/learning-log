{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Edit(journal/**)",
      "Edit(notes/**)",
      "Edit(troubleshooting/**)",
      "Edit(references/**)",
      "Edit(templates/**)",
      "Edit(scripts/**)",
      "Edit(assets/**)",
      "Edit(_inbox.md)",
      "Edit(_status.md)",
      "Edit(README.md)",
      "Edit(CLAUDE.md)",
      "Edit(.claude/**)",
      "Bash(git *)",
      "Bash(bash scripts/*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(find *)",
      "Bash(cd *)",
      "Bash(echo *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"E:/code/learning-log/scripts/session-start.sh\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"E:/code/learning-log\" && git add -A && if ! git diff --cached --quiet; then git commit -m \"chore: [auto-save] $(date '+%Y-%m-%d %H:%M')\"; fi"
          }
        ]
      }
    ]
  }
}
